{
  "name": "@eushop/web",
  "version": "0.2.1",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});try{require('fs').unlinkSync('tsconfig.tsbuildinfo')}catch(_){}\" && next build",
    "start": "next start --port 3000",
    "lint": "node ../../node_modules/eslint/bin/eslint.js -c eslint.config.mjs .",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@eushop/api-router": "workspace:*",
    "@eushop/auth": "workspace:*",
    "@eushop/catalog": "workspace:*",
    "@eushop/tokens": "workspace:*",
    "@eushop/i18n": "workspace:*",
    "@eushop/ui": "workspace:*",
    "@eushop/validators": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "@tanstack/react-query": "^5.62.7",
    "@trpc/client": "^11.0.0-rc.660",
    "@trpc/react-query": "^11.0.0-rc.660",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.469.0",
    "next": "^15.1.3",
    "next-intl": "^3.26.3",
    "next-themes": "^0.4.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "superjson": "^2.2.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@sentry/nextjs": "^8.45.0",
    "posthog-js": "^1.200.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eushop/config": "workspace:*",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.0.0-beta.8",
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^10.5.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0-beta.8",
    "typescript": "^6.0.3"
  }
