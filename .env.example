# ==============================================================================
# Eushop environment template — copy to .env at repo root for local dev
# ==============================================================================

NODE_ENV=development

# ---- Database ----------------------------------------------------------------
DATABASE_URL=postgresql://eushop:eushop@localhost:5432/eushop
REDIS_URL=redis://localhost:6379

# ---- Search ------------------------------------------------------------------
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=eushopDevMeiliMasterKey

# ---- Auth (Better Auth) ------------------------------------------------------
BETTER_AUTH_SECRET=replace-me-with-a-random-32-byte-string
BETTER_AUTH_URL=http://localhost:3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ---- Email (Resend) ----------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Eushop <noreply@eushop.eu>"

# ---- Storage (Cloudflare R2) -------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=eushop-media
R2_PUBLIC_URL=https://media.eushop.eu

# ---- Background jobs (Inngest) -----------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Push notifications (Expo) -----------------------------------------------
EXPO_PUSH_ACCESS_TOKEN=

# ---- Realtime chat (PartyKit) ------------------------------------------------
PARTYKIT_HOST=http://localhost:1999

# ---- Observability -----------------------------------------------------------
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://eu.posthog.com

# ---- API (rate limits; optional in dev) --------------------------------------
API_RATE_LIMIT_PER_MIN=240
API_AUTH_RATE_LIMIT_PER_MIN=60

# ---- Public (web) ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_PARTYKIT_HOST=http://localhost:1999
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ---- Public (mobile) ---------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_PARTYKIT_HOST=http://localhost:1999
