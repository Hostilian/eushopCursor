# ==============================================================================
# Eushop environment template — copy to .env at repo root for local dev
# ==============================================================================

NODE_ENV=development

# ---- Database ----------------------------------------------------------------
DATABASE_URL=postgresql://eushop:eushop@localhost:5432/eushop
REDIS_URL=redis://localhost:6379

# ---- Search ------------------------------------------------------------------
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=eushopDevMeiliMasterKey

# ---- Auth (Better Auth) ------------------------------------------------------
# Must be ≥32 random bytes in production. This placeholder is long enough for dev warnings.
BETTER_AUTH_SECRET=dev-only-replace-me-openssl-rand-base64-32-chars-min-ok-xxxxxxxx
BETTER_AUTH_URL=http://localhost:3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ---- Email (Resend) ----------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Eushop <noreply@eushop.eu>"

# ---- Storage (Cloudflare R2) -------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=eushop-media
R2_PUBLIC_URL=https://media.eushop.eu

# ---- Background jobs (Inngest) -----------------------------------------------
# Same key for `apps/api` and for Next.js (`apps/web`, `apps/admin`) so RSC /
# Server Action tRPC callers can enqueue jobs (e.g. catalog.reindex after UGC).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Push notifications (Expo) -----------------------------------------------
EXPO_PUSH_ACCESS_TOKEN=

# ---- Realtime chat (PartyKit) ------------------------------------------------
PARTYKIT_HOST=http://localhost:1999

# ---- Payments (Stripe Connect) ----------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: Connect OAuth client for hosted onboarding
STRIPE_CONNECT_CLIENT_ID=

# ---- Identity verification (Veriff or Onfido) -------------------------------
VERIFF_API_KEY=
VERIFF_BASE_URL=https://stationapi.veriff.com

# ---- Observability -----------------------------------------------------------
SENTRY_DSN=
# Browser SDK (Next.js web) — use a separate DSN without secret key if you split projects
NEXT_PUBLIC_SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://eu.posthog.com

# ---- API (rate limits; optional in dev) --------------------------------------
API_RATE_LIMIT_PER_MIN=240
API_AUTH_RATE_LIMIT_PER_MIN=60

# ---- Investor surfaces -------------------------------------------------------
# Comma-separated tokens (one per fund/recipient) that unlock /investors. Leave
# empty to keep the long-form deck fully gated; the public stub still renders.
INVESTOR_ACCESS_TOKENS=

# ---- Web demo / staging showcase ---------------------------------------------
# When unset or 0, `?demo=1` is ignored and the demo cookie is cleared. Set to 1
# only on staging or controlled demos so empty marketplace pages can show a
# labelled showcase from the curated catalog (never mixed with /traction metrics).
ENABLE_DEMO_MODE=

# ---- Public (web) ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_PARTYKIT_HOST=http://localhost:1999
NEXT_PUBLIC_POSTHOG_KEY=
# Optional hostname only (no protocol), for next/image remotePatterns when media is not on media.eushop.eu
NEXT_PUBLIC_MEDIA_HOSTNAME=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
# Press page and media inquiries (shown on /press)
NEXT_PUBLIC_PRESS_EMAIL=press@eushop.eu
# Imprint (Impressum) — replace with counsel-approved values before launch
NEXT_PUBLIC_LEGAL_REGISTERED_NAME=Eushop Sàrl (example — replace after incorporation)
NEXT_PUBLIC_LEGAL_REGISTERED_OFFICE=Full address, Luxembourg (example)
NEXT_PUBLIC_LEGAL_REGISTER_ID=RCS Luxembourg number (example)
NEXT_PUBLIC_LEGAL_VAT_ID=LU12345678 (if applicable)
NEXT_PUBLIC_LEGAL_SUPERVISORY_NOTE=Named regulator if required after legal review (optional)
# Stripe.js (when Connect / Checkout is wired in the web app)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---- Public (mobile) ---------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_PARTYKIT_HOST=http://localhost:1999
