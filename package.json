{
  "name": "eushop",
  "version": "0.1.0",
  "private": true,
  "description": "City-to-city peer marketplace — spare luggage capacity on real routes (price or bids) plus finder-fee requests; location-first discovery and rich profiles.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "node ./node_modules/turbo/bin/turbo run build",
    "dev": "node ./node_modules/turbo/bin/turbo run dev",
    "lint": "node ./node_modules/turbo/bin/turbo run lint",
    "typecheck": "node ./node_modules/turbo/bin/turbo run typecheck",
    "verify": "pnpm typecheck && pnpm lint && pnpm build",
    "demo": "node ./node_modules/turbo/bin/turbo run dev --filter=@eushop/web --filter=@eushop/api-server",
    "demo:stack": "pnpm db:up && pnpm demo",
    "test": "node ./node_modules/turbo/bin/turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "node ./node_modules/turbo/bin/turbo run clean && rimraf node_modules .turbo",
    "db:up": "docker compose up -d postgres meilisearch redis mailhog",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "pnpm --filter @eushop/db generate",
    "db:migrate": "pnpm --filter @eushop/db migrate",
    "db:seed": "pnpm --filter @eushop/db seed",
    "db:studio": "pnpm --filter @eushop/db studio",
    "search:index": "pnpm --filter @eushop/api-server search:index",
    "api:dev:bun": "pnpm --filter @eushop/api-server dev:bun",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
